{{#*inline "body"}}
<div class="content-area">
<main class="site-main">

    {{#with post}}

    <article class="{{post_class}} gh-article">
        <header class="gh-article-header gh-canvas">
            {{> partials/feature-image}}

            <h1 class="gh-article-title">{{title}}</h1>

            {{#if custom_excerpt}}
                <div class="gh-article-excerpt">{{custom_excerpt}}</div>
            {{/if}}
        </header>

        <div class="gh-content gh-canvas">
            {{{content}}}
        </div>
    </article>

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments}}
        </div>
    {{/if}}

    {{/with}}

    {{#if @root.custom.show_related_posts}}
        {{> partials/related-posts}}
    {{/if}}

</main>
</div>
{{/inline}}
{{> default}}