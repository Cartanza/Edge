{{#*inline "body"}}
<div class="content-area">
<main class="site-main">

    {{#with post}}

    <article class="{{post_class}} gh-article">

        {{#match show_title_and_feature_image}}
            <header class="gh-article-header gh-canvas">
                {{> partials/feature-image}}

                <h1 class="gh-article-title">{{title}}</h1>

                {{#if custom_excerpt}}
                    <div class="gh-article-excerpt">{{custom_excerpt}}</div>
                {{/if}}
            </header>
        {{/match}}

        <div class="gh-content gh-canvas">
            {{{content}}}
        </div>
    </article>

    {{/with}}

</main>
</div>
{{/inline}}
{{> default}}